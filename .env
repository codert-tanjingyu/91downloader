# =============================================================
# 91downloader 配置文件 —— 敏感信息请勿提交至版本控制
# =============================================================

# --- 代理设置 ---
# 支持 http/https/socks5 格式，留空则不使用代理
# 示例：
#   PROXY=http://127.0.0.1:7890
#   PROXY=socks5://127.0.0.1:7891
PROXY=

# --- Cookie ---
# 将浏览器导出的完整 Cookie 字符串粘贴至此处（格式：key1=val1; key2=val2）
COOKIE=

# --- User-Agent ---
# 留空则使用 config.py 中的默认值
USER_AGENT=

# --- 目标网站 Referer ---
# 用于请求 TS 分片和 Key 时携带的 Referer 头
REFERER=https://www.91porn.com/
